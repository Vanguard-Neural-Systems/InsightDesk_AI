# Model Context Protocol (MCP) Backend
# Point this to the running Mock MCP Server (or production Data Access Gateway)
MCP_SERVER_URL=http://localhost:8100
MCP_API_KEY=mock-enterprise-key

# Note: Add provider keys if the reasoning engine is upgraded to make real LLM calls
GEMINI_API_KEY=your-gemini-api-key-here
GROQ_API_KEY=your-groq-api-key-here
PRIMARY_LLM_PROVIDER=gemini
